// ds9-rust main window. Geometry mirrors SAOImage DS9 (menubar / info row /
// colorbar | canvas | panner+magnifier / button row / status bar). Aesthetic
// is intentional: deep slate background, teal accent, monospace readouts —
// reads as a dark-room observatory console rather than a generic Material app.

import { ScrollView, LineEdit, Button } from "std-widgets.slint";

// Markers are rendered in canvas/image-pixel space (0-based, top-left, y-down).
// Conversion from DS9's 1-based, bottom-up FITS coords happens in Rust.
struct Mark {
    kind: int,        // 0 = circle, 1 = box (axis-aligned)
    cx: float,        // image-space pixel center
    cy: float,
    rx: float,        // half-extent in x
    ry: float,        // half-extent in y
    color: color,
    selected: bool,   // emphasised when the matching catalog row is selected
}

// One row of the catalog table panel. `id` is a short label (NUMBER or row
// index), `mag` is preformatted ("—" if no magnitude column was found).
struct CatRow {
    id: string,
    x: float,         // FITS image-pixel coords (1-based)
    y: float,
    mag: string,
}

// Floating text annotation (DS9 `text(x,y)` regions). Coords are in display
// space (0-based, y-down — matches `Mark`).
struct TextMark {
    x: float,
    y: float,
    body: string,
    color: color,
}

// One row in the HDU navigator panel. Rust populates the model when the panel
// opens; clicking a loadable row asks Rust to load that HDU into the active
// frame.
struct HduRow {
    idx: int,
    label: string,    // pre-formatted "[0] IMAGE 4096×4096"
    loadable: bool,
    active: bool,
}

global Style {
    out property <color> bg-deep:    #0b0e13;
    out property <color> bg-panel:   #161b22;
    out property <color> bg-sunken:  #0f1319;
    out property <color> bg-hover:   #1f242c;
    out property <color> bg-active:  #2a3038;
    out property <color> bg-canvas:  #000000;
    out property <color> border:     #2a3038;
    out property <color> border-hi:  #3a424e;
    out property <color> accent:     #4ec9b0;
    out property <color> accent-dim: #2a665d;
    out property <color> text:       #e6edf3;
    out property <color> text-dim:   #7d8590;
    out property <color> warn:       #ffa657;

    out property <length> row-h-menu:   24px;
    out property <length> row-h-info:   22px;
    out property <length> row-h-mode:   30px;
    out property <length> row-h-status: 22px;
    out property <length> sidebar-w:    150px;
    out property <length> colorbar-w:   28px;

    out property <string> mono: "monospace";
}

component MenuBarItem inherits Rectangle {
    in property <string> label;
    in property <[string]> items;
    callback chosen(string);

    background: ta.has-hover ? Style.bg-hover : transparent;

    HorizontalLayout {
        padding-left:  10px;
        padding-right: 10px;
        Text {
            text: root.label;
            color: Style.text;
            font-size: 12px;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        clicked => { popup.show(); }
    }

    popup := PopupWindow {
        x: 0px;
        y: root.height;
        close-policy: close-on-click-outside;
        Rectangle {
            background: Style.bg-panel;
            border-color: Style.border-hi;
            border-width: 1px;
            // shadow rule on top to anchor it visually under the menubar accent
            Rectangle { y: 0px; height: 1px; background: Style.accent-dim; }
            VerticalLayout {
                padding-top:    4px;
                padding-bottom: 4px;
                spacing: 0px;
                for item in root.items: Rectangle {
                    height: item == "—" ? 7px : 22px;
                    background: item == "—"
                        ? transparent
                        : (itemta.has-hover ? Style.bg-hover : transparent);
                    if item == "—" : Rectangle {
                        x: 8px; y: parent.height / 2;
                        width: parent.width - 16px;
                        height: 1px;
                        background: Style.border;
                    }
                    if item != "—" : HorizontalLayout {
                        padding-left:  14px;
                        padding-right: 14px;
                        Text {
                            text: item;
                            color: Style.text;
                            font-size: 11px;
                            font-family: Style.mono;
                            vertical-alignment: center;
                        }
                    }
                    itemta := TouchArea {
                        enabled: item != "—";
                        clicked => {
                            root.chosen(item);
                            popup.close();
                        }
                    }
                }
            }
        }
    }
}

component ModeButton inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked;

    border-radius: 3px;
    border-width: 1px;
    border-color: root.active ? Style.accent : Style.border;
    background: ta.has-hover
        ? Style.bg-hover
        : (root.active ? Style.accent-dim : Style.bg-panel);

    HorizontalLayout {
        padding-left:  9px;
        padding-right: 9px;
        Text {
            text: root.label;
            color: root.active ? Style.text : Style.text-dim;
            font-size: 11px;
            vertical-alignment: center;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

component InfoCell inherits Rectangle {
    in property <string> caption;
    in property <string> value;
    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 4px;
        Text {
            text: root.caption;
            color: Style.text-dim;
            font-size: 10px;
            font-family: Style.mono;
            vertical-alignment: center;
        }
        Text {
            text: root.value;
            color: Style.text;
            font-size: 11px;
            font-family: Style.mono;
            vertical-alignment: center;
        }
    }
}

component Colorbar inherits Rectangle {
    in property <image> strip;
    in property <string> caption;
    background: Style.bg-sunken;
    border-color: Style.border;
    border-width: 1px;
    Image {
        x: 4px; y: 4px;
        width:  parent.width  - 8px;
        height: parent.height - 8px;
        source: root.strip;
        image-rendering: smooth;
        image-fit: fill;
    }
    Text {
        x: 4px; y: parent.height - 14px;
        text: root.caption;
        color: Style.text;
        font-size: 9px;
        font-family: Style.mono;
    }
}

/// Small thumbnail of the full image plus a viewport rect showing what the
/// main canvas is currently looking at. DS9's Panner.
component Panner inherits Rectangle {
    in property <string> caption;
    in property <image> source;
    in property <int> img-w;
    in property <int> img-h;
    // current main-canvas viewport, expressed as image-pixel coords
    in property <float> view-x;     // image-x at canvas origin
    in property <float> view-y;
    in property <float> view-w;     // image-pixels visible across canvas
    in property <float> view-h;
    callback panned(float, float);  // emits image-x, image-y of click

    background: Style.bg-sunken;
    border-color: Style.border;
    border-width: 1px;

    Text {
        x: 6px; y: 4px;
        text: root.caption;
        color: Style.text-dim;
        font-size: 10px;
        font-family: Style.mono;
    }

    // The thumbnail occupies an inner box; we need its size to project
    // viewport coords. Compute a contain-fit rect ourselves so the overlay
    // rect lands on top of the actual image bounds (not the surrounding pad).
    property <length> inner-x: 6px;
    property <length> inner-y: 18px;
    property <length> inner-w: root.width  - 12px;
    property <length> inner-h: root.height - 22px;
    property <float>  aspect-img: img-h > 0 ? (img-w / 1.0) / (img-h / 1.0) : 1.0;
    property <float>  aspect-box: inner-h > 0px ? (inner-w / 1px) / (inner-h / 1px) : 1.0;
    property <length> fit-w: aspect-img > aspect-box ? inner-w : inner-h * aspect-img;
    property <length> fit-h: aspect-img > aspect-box ? inner-w / aspect-img : inner-h;
    property <length> fit-x: inner-x + (inner-w - fit-w) / 2;
    property <length> fit-y: inner-y + (inner-h - fit-h) / 2;

    Image {
        x: root.fit-x; y: root.fit-y;
        width: root.fit-w; height: root.fit-h;
        source: root.source;
        image-rendering: smooth;
        image-fit: fill;
    }

    // viewport rectangle (clamped into the thumbnail bounds)
    if root.img-w > 0 && root.img-h > 0 && root.view-w > 0 && root.view-h > 0:
    Rectangle {
        property <length> sx: root.fit-w * (root.view-x / root.img-w);
        property <length> sy: root.fit-h * (root.view-y / root.img-h);
        property <length> sw: root.fit-w * (root.view-w / root.img-w);
        property <length> sh: root.fit-h * (root.view-h / root.img-h);
        x: root.fit-x + max(0px, min(root.fit-w, sx));
        y: root.fit-y + max(0px, min(root.fit-h, sy));
        width:  max(2px, min(root.fit-w - (self.x - root.fit-x), sw));
        height: max(2px, min(root.fit-h - (self.y - root.fit-y), sh));
        background: transparent;
        border-color: Style.accent;
        border-width: 1px;
    }

    // click anywhere in the thumbnail to recenter
    TouchArea {
        x: root.fit-x; y: root.fit-y;
        width: root.fit-w; height: root.fit-h;
        clicked => {
            if (root.fit-w > 0px && root.fit-h > 0px) {
                root.panned(
                    (self.mouse-x / root.fit-w) * root.img-w,
                    (self.mouse-y / root.fit-h) * root.img-h);
            }
        }
    }
}

/// High-zoom view of the area around the cursor. DS9's Magnifier.
component Magnifier inherits Rectangle {
    in property <string> caption;
    in property <image> source;
    in property <int> img-w;
    in property <int> img-h;
    in property <float> cursor-x;   // image-pixel coord
    in property <float> cursor-y;
    in property <float> mag: 8.0;   // pixel-magnification factor

    background: Style.bg-sunken;
    border-color: Style.border;
    border-width: 1px;

    Text {
        x: 6px; y: 4px;
        text: root.caption;
        color: Style.text-dim;
        font-size: 10px;
        font-family: Style.mono;
    }

    property <length> inner-x: 6px;
    property <length> inner-y: 18px;
    property <length> inner-w: root.width  - 12px;
    property <length> inner-h: root.height - 22px;
    property <float>  src-w-pix: max(1.0, (inner-w / 1px) / mag);
    property <float>  src-h-pix: max(1.0, (inner-h / 1px) / mag);

    Rectangle {
        x: root.inner-x; y: root.inner-y;
        width: root.inner-w; height: root.inner-h;
        clip: true;
        background: #000000;

        if root.img-w > 0 && root.img-h > 0:
        Image {
            x: 0px; y: 0px;
            width:  parent.width;
            height: parent.height;
            source: root.source;
            image-rendering: pixelated;
            image-fit: fill;
            source-clip-x:      max(0, min(root.img-w - Math.round(root.src-w-pix),
                                Math.round(root.cursor-x - root.src-w-pix / 2)));
            source-clip-y:      max(0, min(root.img-h - Math.round(root.src-h-pix),
                                Math.round(root.cursor-y - root.src-h-pix / 2)));
            source-clip-width:  max(1, Math.round(root.src-w-pix));
            source-clip-height: max(1, Math.round(root.src-h-pix));
        }

        // crosshair
        Rectangle { x: parent.width / 2 - 0.5px; y: 0px; width: 1px;
                    height: parent.height; background: #4ec9b080; }
        Rectangle { x: 0px; y: parent.height / 2 - 0.5px; width: parent.width;
                    height: 1px; background: #4ec9b080; }
    }
}

/// Scrollable catalog table. Columns: id, x, y, mag. Click a row to ask the
/// host to recenter the canvas on that source.
component CatalogPanel inherits Rectangle {
    in property <string> caption;
    in property <[CatRow]> rows: [];
    in property <int> selected: -1;
    callback row-clicked(int);

    background: Style.bg-sunken;
    border-color: Style.border;
    border-width: 1px;

    property <length> row-h: 16px;

    Text {
        x: 6px; y: 4px;
        text: root.caption + "  (" + root.rows.length + ")";
        color: Style.text-dim;
        font-size: 10px;
        font-family: Style.mono;
    }

    // header
    Rectangle {
        x: 6px; y: 18px;
        width: parent.width - 12px;
        height: 14px;
        background: Style.bg-panel;
        HorizontalLayout {
            padding-left: 4px; padding-right: 4px;
            Text { text: "id";  color: Style.text-dim; font-size: 9px; font-family: Style.mono;
                   horizontal-stretch: 1; vertical-alignment: center; }
            Text { text: "x";   color: Style.text-dim; font-size: 9px; font-family: Style.mono;
                   horizontal-stretch: 1; vertical-alignment: center; horizontal-alignment: right; }
            Text { text: "y";   color: Style.text-dim; font-size: 9px; font-family: Style.mono;
                   horizontal-stretch: 1; vertical-alignment: center; horizontal-alignment: right; }
            Text { text: "mag"; color: Style.text-dim; font-size: 9px; font-family: Style.mono;
                   horizontal-stretch: 1; vertical-alignment: center; horizontal-alignment: right; }
        }
    }

    sv := ScrollView {
        x: 6px; y: 34px;
        width: parent.width - 12px;
        height: parent.height - 38px;

        // auto-scroll the selected row into view
        changed viewport-y => { /* nothing — but binding required to permit assignment */ }

        VerticalLayout {
            spacing: 0px;
            for r[i] in root.rows: Rectangle {
                height: root.row-h;
                background: i == root.selected
                    ? Style.accent-dim
                    : (rta.has-hover ? Style.bg-hover : transparent);
                HorizontalLayout {
                    padding-left: 4px; padding-right: 4px;
                    Text { text: r.id; color: Style.text; font-size: 10px; font-family: Style.mono;
                           horizontal-stretch: 1; vertical-alignment: center; }
                    Text { text: round(r.x * 10) / 10; color: Style.text-dim;
                           font-size: 10px; font-family: Style.mono;
                           horizontal-stretch: 1; vertical-alignment: center; horizontal-alignment: right; }
                    Text { text: round(r.y * 10) / 10; color: Style.text-dim;
                           font-size: 10px; font-family: Style.mono;
                           horizontal-stretch: 1; vertical-alignment: center; horizontal-alignment: right; }
                    Text { text: r.mag; color: Style.text-dim;
                           font-size: 10px; font-family: Style.mono;
                           horizontal-stretch: 1; vertical-alignment: center; horizontal-alignment: right; }
                }
                rta := TouchArea {
                    clicked => { root.row-clicked(i); }
                }
            }
        }
    }

    // Slint exposes ScrollView.viewport-y as a length we can read/write.
    // When the selected index changes from outside, reveal that row.
    changed selected => {
        if (root.selected >= 0) {
            sv.viewport-y = -1px * root.selected * (root.row-h / 1px) + sv.height / 2 - root.row-h;
        }
    }
}

export component MainWindow inherits Window {
    title: "ds9-rust";
    background: Style.bg-deep;
    preferred-width:  1180px;
    preferred-height: 760px;
    min-width:  720px;
    min-height: 480px;

    // ---- image / data ----
    in-out property <image> fits-image;
    in-out property <int>   fits-width: 0;
    in-out property <int>   fits-height: 0;

    // ---- view state ----
    in-out property <length> view-pan-x: 0px;
    in-out property <length> view-pan-y: 0px;
    in-out property <float>  view-zoom: 1.0;

    // ---- pixel pipeline state (display only — Rust owns the truth) ----
    in-out property <image>  colorbar-strip;
    in-out property <string> active-cmap:    "grey";
    in-out property <string> active-stretch: "linear";
    in-out property <string> active-limits:  "zscale";

    // ---- regions ----
    in-out property <[Mark]> markers: [];

    // ---- catalog ----
    in-out property <[CatRow]> catalog-rows: [];
    in-out property <int>      catalog-selected: -1;

    // ---- analysis overlays ----
    in-out property <image> histogram-image;
    in-out property <image> contour-image;
    in-out property <image> projection-image;
    in-out property <bool>  histogram-visible:  false;
    in-out property <bool>  contour-visible:    false;
    in-out property <bool>  projection-visible: false;
    in-out property <string> projection-caption: "PROJECTION";
    in-out property <image> radial-image;
    in-out property <bool>  radial-visible: false;
    in-out property <string> radial-caption: "RADIAL PROFILE";

    // ---- coordinate grid overlay (WCS RA/Dec) ----
    in-out property <image> grid-image;
    in-out property <bool>  grid-visible: false;

    // ---- line / vector / polygon / compass overlay (region shapes that don't
    //      fit a Mark Rectangle) — baked at frame dims, scaled by view-zoom ----
    in-out property <image> line-image;
    in-out property <bool>  line-visible: false;

    // ---- floating text annotations (DS9 `text(...)` regions) ----
    in-out property <[TextMark]> text-marks: [];

    // ---- frame-lock toggles (display-only — Rust owns the truth) ----
    in-out property <bool> lock-zoom:  false;
    in-out property <bool> lock-pan:   false;
    in-out property <bool> lock-cmap:  false;
    in-out property <bool> lock-scale: false;

    // ---- session crosshair (image-display coords, set by Rust) ----
    in-out property <bool>  crosshair-visible: false;
    in-out property <float> crosshair-x: 0;     // display-space (0-based, y-down)
    in-out property <float> crosshair-y: 0;

    // ---- side-panel visibility ----
    in-out property <bool>  panner-visible:    true;
    in-out property <bool>  magnifier-visible: true;

    // ---- info readouts ----
    in-out property <string> info-frame:    "0/0";
    in-out property <string> info-filename: "—";
    in-out property <string> info-object:   "—";
    in-out property <string> info-coords:   "x: ——      y: ——";
    in-out property <string> info-value:    "value: ——";
    in-out property <string> info-wcs:      "wcs: ——";
    in-out property <string> status-text:   "ready";

    // ---- mode ----
    in-out property <string> active-mode: "pan";

    // ---- last cursor position in image-pixel space (drives the magnifier) ----
    in-out property <float> cursor-image-x: 0;
    in-out property <float> cursor-image-y: 0;

    // ---- region drag state — Rust flips this true during pointer-down when a
    //      marker was hit (so the canvas suppresses view-pan and click-drop) ----
    in-out property <bool> marker-drag-active: false;

    // ---- blink mode toggle (Rust drives a 500-ms timer that calls Frame Next while on) ----
    in-out property <bool> blink-active: false;

    // ---- preferences panel (default cmap/stretch/limits/smooth/bin/blink) ----
    in-out property <bool>   prefs-visible: false;
    in-out property <string> prefs-cmap:    "grey";
    in-out property <string> prefs-stretch: "linear";
    in-out property <string> prefs-limits:  "zscale";
    in-out property <string> prefs-smooth:  "off";
    in-out property <string> prefs-bin:     "1";
    in-out property <string> prefs-blink:   "500";
    in-out property <string> prefs-status:  "";
    callback prefs-apply();
    callback prefs-save();
    callback prefs-reset();

    // ---- region property editor (operates on the selected marker) ----
    in-out property <bool>   region-prop-visible: false;
    in-out property <string> region-prop-kind:    "—";
    in-out property <string> region-prop-x:       "";
    in-out property <string> region-prop-y:       "";
    in-out property <string> region-prop-size1:   "";    // r / w / a / r_outer / dx
    in-out property <string> region-prop-size2:   "";    // -- / h / b / r_inner / dy
    in-out property <string> region-prop-angle:   "";    // theta_deg
    in-out property <string> region-prop-color:   "";    // hex "#rrggbb"
    in-out property <string> region-prop-text:    "";    // text body (Text shape)
    in-out property <string> region-prop-status:  "";
    callback region-prop-apply();
    callback region-prop-revert();

    // ---- HDU navigator panel ----
    in-out property <bool>     hdu-panel-visible: false;
    in-out property <[HduRow]> hdu-rows: [];
    in-out property <string>   hdu-source-name: "—";
    // ---- HDU movie toggle (Rust drives an 800-ms timer that loads the next
    //      loadable HDU while on) ----
    in-out property <bool>     hdu-movie-active: false;
    callback hdu-row-clicked(int);

    // ---- main canvas viewport (image-pixel coords) — derived from the
    //      canvas Rectangle's actual size, populated below ----
    in-out property <length> canvas-w: 800px;
    in-out property <length> canvas-h: 600px;
    property <float>  vp-x: view-zoom > 0 ? -view-pan-x / 1px / view-zoom : 0;
    property <float>  vp-y: view-zoom > 0 ? -view-pan-y / 1px / view-zoom : 0;
    property <float>  vp-w: view-zoom > 0 ? canvas-w / 1px / view-zoom : 0;
    property <float>  vp-h: view-zoom > 0 ? canvas-h / 1px / view-zoom : 0;

    // ---- callbacks to Rust ----
    callback request-open-file();
    callback canvas-mouse-move(/*image-x*/ float, /*image-y*/ float);
    callback canvas-clicked(/*image-x*/ float, /*image-y*/ float);
    callback canvas-pressed(/*image-x*/ float, /*image-y*/ float);
    callback canvas-released();
    callback view-changed();
    callback set-mode(string);
    callback menu-action(/*menu*/ string, /*item*/ string);
    callback catalog-row-activated(/*index*/ int);

    public function recenter-view-on(ix: float, iy: float) {
        // place image-pixel (ix,iy) at the centre of the canvas
        self.view-pan-x = self.canvas-w / 2 - ix * 1px * self.view-zoom;
        self.view-pan-y = self.canvas-h / 2 - iy * 1px * self.view-zoom;
    }

    function set-zoom-anchored(new-zoom: float, ax: length, ay: length) {
        // keep image-space point under (ax,ay) stationary
        if (root.view-zoom > 0) {
            self.view-pan-x = ax - (ax - self.view-pan-x) * (new-zoom / self.view-zoom);
            self.view-pan-y = ay - (ay - self.view-pan-y) * (new-zoom / self.view-zoom);
        }
        self.view-zoom = new-zoom;
    }

    VerticalLayout {
        spacing: 0px;

        // ---------------- menu bar ----------------
        Rectangle {
            background: Style.bg-panel;
            height: Style.row-h-menu;
            HorizontalLayout {
                spacing: 0px;
                MenuBarItem {
                    label: "File";
                    items: ["Open…", "HDU Navigator…", "Next HDU", "—",
                            "Save Image…", "Save FITS…", "Save TIFF…", "Save JPEG…", "Save PostScript…",
                            "—", "Print…", "—", "Quit"];
                    chosen(it) => { root.menu-action("File", it); }
                }
                MenuBarItem {
                    label: "Edit";
                    items: ["Undo", "Redo", "—", "Cut", "Copy", "Paste", "—",
                            "Crop to Selected", "Reset Crop", "—",
                            "Preferences…"];
                    chosen(it) => { root.menu-action("Edit", it); }
                }
                MenuBarItem {
                    label: "View";
                    items: ["Panner", "Magnifier", "Coordinate Grid", "Crosshair", "—",
                            "Info Panel", "Buttons", "Colorbar"];
                    chosen(it) => { root.menu-action("View", it); }
                }
                MenuBarItem {
                    label: "Frame";
                    items: ["New Frame", "Delete Frame", "—", "Next", "Previous", "—",
                            "Match…", "Blink", "RGB Composite", "HDU Movie", "—",
                            "Rotate 180°", "Flip Horizontal", "Flip Vertical", "Reset Orientation",
                            "—",
                            "Lock Zoom", "Lock Pan", "Lock Color", "Lock Scale"];
                    chosen(it) => { root.menu-action("Frame", it); }
                }
                MenuBarItem {
                    label: "Bin";
                    items: ["1", "2", "4", "8", "16", "32", "—",
                            "Average", "Sum", "Sub-sample"];
                    chosen(it) => { root.menu-action("Bin", it); }
                }
                MenuBarItem {
                    label: "Zoom";
                    items: ["Zoom In", "Zoom Out", "Fit", "Reset", "—",
                            "1×", "2×", "4×", "8×", "16×"];
                    chosen(it) => { root.menu-action("Zoom", it); }
                }
                MenuBarItem {
                    label: "Scale";
                    items: ["linear", "log", "sqrt", "squared", "asinh", "sinh", "—",
                            "minmax", "zscale"];
                    chosen(it) => { root.menu-action("Scale", it); }
                }
                MenuBarItem {
                    label: "Color";
                    items: ["grey", "red", "green", "blue", "—",
                            "a", "b", "bb", "heat", "cool", "rainbow", "sls", "hsv", "—",
                            "Load Custom…", "Clear Custom"];
                    chosen(it) => { root.menu-action("Color", it); }
                }
                MenuBarItem {
                    label: "Region";
                    items: ["New", "Load…", "Save…", "—", "Delete Selected", "Delete All", "—",
                            "Projection…", "Radial Profile…", "Centroid", "Properties…",
                            "—", "Info"];
                    chosen(it) => { root.menu-action("Region", it); }
                }
                MenuBarItem {
                    label: "WCS";
                    items: ["FK5", "ICRS", "Galactic", "—", "Degrees", "Sexagesimal"];
                    chosen(it) => { root.menu-action("WCS", it); }
                }
                MenuBarItem {
                    label: "Analysis";
                    items: ["Pixel Table…", "Histogram…", "Statistics…", "Contour Levels…",
                            "—", "Smooth (cycle)", "Smooth Off", "—",
                            "Smooth Gaussian", "Smooth Boxcar", "Smooth Median"];
                    chosen(it) => { root.menu-action("Analysis", it); }
                }
                MenuBarItem {
                    label: "Catalog";
                    items: ["Load…", "Clear", "—", "Run SExtractor…", "—", "Info"];
                    chosen(it) => { root.menu-action("Catalog", it); }
                }
                MenuBarItem {
                    label: "Help";
                    items: ["About ds9-rust"];
                    chosen(it) => { root.menu-action("Help", it); }
                }
                Rectangle { horizontal-stretch: 1; }
            }
        }
        Rectangle { height: 1px; background: Style.accent-dim; }  // teal accent rule

        // ---------------- info row ----------------
        Rectangle {
            background: Style.bg-sunken;
            height: Style.row-h-info;
            HorizontalLayout {
                spacing: 0px;
                InfoCell { caption: "FRM";   value: root.info-frame;    horizontal-stretch: 0; }
                Rectangle { width: 1px; background: Style.border; }
                InfoCell { caption: "FILE";  value: root.info-filename; horizontal-stretch: 2; }
                Rectangle { width: 1px; background: Style.border; }
                InfoCell { caption: "OBJ";   value: root.info-object;   horizontal-stretch: 2; }
                Rectangle { width: 1px; background: Style.border; }
                InfoCell { caption: "POS";   value: root.info-coords;   horizontal-stretch: 1; }
                Rectangle { width: 1px; background: Style.border; }
                InfoCell { caption: "VAL";   value: root.info-value;    horizontal-stretch: 1; }
                Rectangle { width: 1px; background: Style.border; }
                InfoCell { caption: "WCS";   value: root.info-wcs;      horizontal-stretch: 1; }
                Rectangle { width: 1px; background: Style.border; }
                InfoCell {
                    caption: "PIPE";
                    value: root.active-stretch + " · " + root.active-limits + " · " + root.active-cmap;
                    horizontal-stretch: 1;
                }
            }
        }
        Rectangle { height: 1px; background: Style.border; }

        // ---------------- main row ----------------
        HorizontalLayout {
            spacing: 0px;
            vertical-stretch: 1;

            // colorbar column
            VerticalLayout {
                width: Style.colorbar-w;
                padding: 4px;
                spacing: 0px;
                Colorbar {
                    strip: root.colorbar-strip;
                    caption: root.active-cmap;
                    vertical-stretch: 1;
                }
            }

            // canvas
            canvas := Rectangle {
                horizontal-stretch: 1;
                clip: true;
                background: Style.bg-canvas;
                border-color: Style.border;
                border-width: 1px;
                changed width  => { root.canvas-w = self.width; }
                changed height => { root.canvas-h = self.height; }

                img := Image {
                    source: root.fits-image;
                    image-rendering: pixelated;
                    x: root.view-pan-x;
                    y: root.view-pan-y;
                    width:  root.fits-width  * 1px * root.view-zoom;
                    height: root.fits-height * 1px * root.view-zoom;
                }

                // contour overlay — same geometry as the main image so they
                // align pixel-for-pixel
                if root.contour-visible: Image {
                    source: root.contour-image;
                    image-rendering: pixelated;
                    x: root.view-pan-x;
                    y: root.view-pan-y;
                    width:  root.fits-width  * 1px * root.view-zoom;
                    height: root.fits-height * 1px * root.view-zoom;
                }

                // RA/Dec coordinate grid overlay (WCS-aware, baked at frame dims)
                if root.grid-visible: Image {
                    source: root.grid-image;
                    image-rendering: pixelated;
                    x: root.view-pan-x;
                    y: root.view-pan-y;
                    width:  root.fits-width  * 1px * root.view-zoom;
                    height: root.fits-height * 1px * root.view-zoom;
                }

                // session crosshair — vertical + horizontal lines through the
                // active frame's projection of the world-locked crosshair point
                if root.crosshair-visible: Rectangle {
                    x: 0px;
                    y: root.view-pan-y + root.crosshair-y * 1px * root.view-zoom - 0.5px;
                    width: parent.width;
                    height: 1px;
                    background: #ff7aa3c0;
                }
                if root.crosshair-visible: Rectangle {
                    x: root.view-pan-x + root.crosshair-x * 1px * root.view-zoom - 0.5px;
                    y: 0px;
                    width: 1px;
                    height: parent.height;
                    background: #ff7aa3c0;
                }

                // line / vector / polygon overlay — baked at frame dims, scaled by view-zoom
                if root.line-visible: Image {
                    source: root.line-image;
                    image-rendering: pixelated;
                    x: root.view-pan-x;
                    y: root.view-pan-y;
                    width:  root.fits-width  * 1px * root.view-zoom;
                    height: root.fits-height * 1px * root.view-zoom;
                }

                // region overlays — drawn in image-pixel space then scaled by view-zoom
                for m in root.markers: Rectangle {
                    x: root.view-pan-x + (m.cx - m.rx) * 1px * root.view-zoom;
                    y: root.view-pan-y + (m.cy - m.ry) * 1px * root.view-zoom;
                    width:  m.rx * 2px * root.view-zoom;
                    height: m.ry * 2px * root.view-zoom;
                    background: transparent;
                    border-color: m.selected ? Style.accent : m.color;
                    border-width: m.selected ? 2.5px : 1.5px;
                    border-radius: m.kind == 0 ? min(self.width, self.height) / 2 : 0px;
                }

                // text annotations
                for t in root.text-marks: Text {
                    x: root.view-pan-x + t.x * 1px * root.view-zoom + 4px;
                    y: root.view-pan-y + t.y * 1px * root.view-zoom - 7px;
                    text: t.body;
                    color: t.color;
                    font-size: 12px;
                    font-family: Style.mono;
                }

                ta := TouchArea {
                    property <length> last-x;
                    property <length> last-y;
                    property <bool>   dragging;

                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down) {
                            self.last-x = self.mouse-x;
                            self.last-y = self.mouse-y;
                            // Ask Rust whether this press hit a marker. Rust will
                            // toggle marker-drag-active synchronously.
                            if (root.view-zoom > 0) {
                                root.canvas-pressed(
                                    (self.mouse-x - root.view-pan-x) / 1px / root.view-zoom,
                                    (self.mouse-y - root.view-pan-y) / 1px / root.view-zoom);
                            }
                            // Only enter view-pan drag if the press did NOT land on a marker.
                            self.dragging = !root.marker-drag-active;
                        }
                        if (e.kind == PointerEventKind.up) {
                            self.dragging = false;
                            if (root.marker-drag-active) {
                                root.canvas-released();
                            } else if (root.view-zoom > 0) {
                                // emit click to Rust (image-space)
                                root.canvas-clicked(
                                    (self.mouse-x - root.view-pan-x) / 1px / root.view-zoom,
                                    (self.mouse-y - root.view-pan-y) / 1px / root.view-zoom);
                            }
                        }
                    }
                    moved => {
                        // image-space cursor coords for the info row + magnifier
                        if (root.view-zoom > 0) {
                            root.cursor-image-x =
                                (self.mouse-x - root.view-pan-x) / 1px / root.view-zoom;
                            root.cursor-image-y =
                                (self.mouse-y - root.view-pan-y) / 1px / root.view-zoom;
                            root.canvas-mouse-move(root.cursor-image-x, root.cursor-image-y);
                        }
                        if (self.dragging) {
                            root.view-pan-x += self.mouse-x - self.last-x;
                            root.view-pan-y += self.mouse-y - self.last-y;
                            self.last-x = self.mouse-x;
                            self.last-y = self.mouse-y;
                            root.view-changed();
                        }
                    }
                    scroll-event(e) => {
                        if (e.delta-y != 0) {
                            root.set-zoom-anchored(
                                max(0.02, min(64.0,
                                    root.view-zoom * (e.delta-y > 0 ? 1.15 : 0.87))),
                                self.mouse-x, self.mouse-y);
                            root.view-changed();
                            return accept;
                        }
                        return reject;
                    }
                }

                // top-left readout — small, like DS9's overlay
                Rectangle {
                    x: 8px; y: 8px;
                    width: ovl.preferred-width  + 12px;
                    height: ovl.preferred-height + 6px;
                    background: #000000a0;
                    border-radius: 2px;
                    border-width: 1px;
                    border-color: Style.accent-dim;
                    ovl := Text {
                        x: 6px;
                        y: (parent.height - self.preferred-height) / 2;
                        text: "zoom " + round(root.view-zoom * 100) / 100
                              + "×    " + root.fits-width + " × " + root.fits-height;
                        color: Style.accent;
                        font-size: 10px;
                        font-family: Style.mono;
                    }
                }

                // floating histogram panel
                if root.histogram-visible: Rectangle {
                    x: 12px;
                    y: parent.height - 250px;
                    width: 380px;
                    height: 230px;
                    background: Style.bg-panel;
                    border-color: Style.border-hi;
                    border-width: 1px;
                    border-radius: 3px;

                    Text {
                        x: 8px; y: 4px;
                        text: "HISTOGRAM  (log counts)";
                        color: Style.accent;
                        font-size: 10px;
                        font-family: Style.mono;
                    }
                    // close button
                    Rectangle {
                        x: parent.width - 22px; y: 3px;
                        width: 18px; height: 18px;
                        background: cta.has-hover ? Style.bg-hover : transparent;
                        border-radius: 2px;
                        Text {
                            x: 4px; y: -1px;
                            text: "×";
                            color: Style.text;
                            font-size: 14px;
                            font-family: Style.mono;
                        }
                        cta := TouchArea {
                            clicked => { root.histogram-visible = false; }
                        }
                    }
                    Image {
                        x: 8px; y: 24px;
                        width:  parent.width  - 16px;
                        height: parent.height - 32px;
                        source: root.histogram-image;
                        image-fit: fill;
                        image-rendering: smooth;
                    }
                }

                // floating Preferences panel
                if root.prefs-visible: Rectangle {
                    x: parent.width - 412px;
                    y: 280px;
                    width: 400px;
                    height: 290px;
                    background: Style.bg-panel;
                    border-color: Style.border-hi;
                    border-width: 1px;
                    border-radius: 3px;

                    Text {
                        x: 8px; y: 4px;
                        text: "PREFERENCES";
                        color: Style.accent;
                        font-size: 10px;
                        font-family: Style.mono;
                    }
                    Rectangle {
                        x: parent.width - 22px; y: 3px;
                        width: 18px; height: 18px;
                        background: prfcta.has-hover ? Style.bg-hover : transparent;
                        border-radius: 2px;
                        Text {
                            x: 4px; y: -1px;
                            text: "×";
                            color: Style.text;
                            font-size: 14px;
                            font-family: Style.mono;
                        }
                        prfcta := TouchArea {
                            clicked => { root.prefs-visible = false; }
                        }
                    }

                    VerticalLayout {
                        x: 8px; y: 24px;
                        width: parent.width - 16px;
                        height: parent.height - 32px;
                        spacing: 4px;

                        HorizontalLayout {
                            spacing: 4px; height: 24px;
                            Text { text: "cmap"; color: Style.text-dim; font-size: 11px;
                                   font-family: Style.mono; vertical-alignment: center; width: 56px; }
                            LineEdit { text <=> root.prefs-cmap;    horizontal-stretch: 1;
                                       placeholder-text: "grey"; }
                        }
                        HorizontalLayout {
                            spacing: 4px; height: 24px;
                            Text { text: "stretch"; color: Style.text-dim; font-size: 11px;
                                   font-family: Style.mono; vertical-alignment: center; width: 56px; }
                            LineEdit { text <=> root.prefs-stretch; horizontal-stretch: 1;
                                       placeholder-text: "linear log sqrt squared asinh sinh"; }
                        }
                        HorizontalLayout {
                            spacing: 4px; height: 24px;
                            Text { text: "limits"; color: Style.text-dim; font-size: 11px;
                                   font-family: Style.mono; vertical-alignment: center; width: 56px; }
                            LineEdit { text <=> root.prefs-limits;  horizontal-stretch: 1;
                                       placeholder-text: "zscale | minmax"; }
                        }
                        HorizontalLayout {
                            spacing: 4px; height: 24px;
                            Text { text: "smooth"; color: Style.text-dim; font-size: 11px;
                                   font-family: Style.mono; vertical-alignment: center; width: 56px; }
                            LineEdit { text <=> root.prefs-smooth;  horizontal-stretch: 1;
                                       placeholder-text: "off | gaussian:N | boxcar:N | median:N"; }
                        }
                        HorizontalLayout {
                            spacing: 4px; height: 24px;
                            Text { text: "bin"; color: Style.text-dim; font-size: 11px;
                                   font-family: Style.mono; vertical-alignment: center; width: 56px; }
                            LineEdit { text <=> root.prefs-bin;     horizontal-stretch: 1;
                                       placeholder-text: "1 2 4 8 16 32"; }
                        }
                        HorizontalLayout {
                            spacing: 4px; height: 24px;
                            Text { text: "blink"; color: Style.text-dim; font-size: 11px;
                                   font-family: Style.mono; vertical-alignment: center; width: 56px; }
                            LineEdit { text <=> root.prefs-blink;   horizontal-stretch: 1;
                                       placeholder-text: "ms (restart needed)"; }
                        }

                        Text {
                            text: root.prefs-status;
                            color: Style.text-dim;
                            font-size: 10px;
                            font-family: Style.mono;
                            wrap: word-wrap;
                        }

                        HorizontalLayout {
                            spacing: 6px; height: 26px;
                            Button { text: "Apply"; clicked => { root.prefs-apply(); } }
                            Button { text: "Save";  clicked => { root.prefs-save(); } }
                            Button { text: "Reset"; clicked => { root.prefs-reset(); } }
                            Rectangle { horizontal-stretch: 1; }
                        }
                    }
                }

                // floating Region Properties editor panel
                if root.region-prop-visible: Rectangle {
                    x: 12px;
                    y: 330px;
                    width: 360px;
                    height: 290px;
                    background: Style.bg-panel;
                    border-color: Style.border-hi;
                    border-width: 1px;
                    border-radius: 3px;

                    Text {
                        x: 8px; y: 4px;
                        text: "REGION PROPERTIES  " + root.region-prop-kind;
                        color: Style.accent;
                        font-size: 10px;
                        font-family: Style.mono;
                    }
                    Rectangle {
                        x: parent.width - 22px; y: 3px;
                        width: 18px; height: 18px;
                        background: rpcta.has-hover ? Style.bg-hover : transparent;
                        border-radius: 2px;
                        Text {
                            x: 4px; y: -1px;
                            text: "×";
                            color: Style.text;
                            font-size: 14px;
                            font-family: Style.mono;
                        }
                        rpcta := TouchArea {
                            clicked => { root.region-prop-visible = false; }
                        }
                    }

                    VerticalLayout {
                        x: 8px; y: 24px;
                        width: parent.width - 16px;
                        height: parent.height - 32px;
                        spacing: 4px;

                        // x / y row
                        HorizontalLayout {
                            spacing: 4px; height: 24px;
                            Text { text: "x"; color: Style.text-dim; font-size: 11px;
                                   font-family: Style.mono; vertical-alignment: center; width: 14px; }
                            LineEdit {
                                text <=> root.region-prop-x;
                                horizontal-stretch: 1;
                                accepted(s) => { root.region-prop-apply(); }
                            }
                            Text { text: "y"; color: Style.text-dim; font-size: 11px;
                                   font-family: Style.mono; vertical-alignment: center; width: 14px; }
                            LineEdit {
                                text <=> root.region-prop-y;
                                horizontal-stretch: 1;
                                accepted(s) => { root.region-prop-apply(); }
                            }
                        }
                        // size1 / size2 row
                        HorizontalLayout {
                            spacing: 4px; height: 24px;
                            Text { text: "s1"; color: Style.text-dim; font-size: 11px;
                                   font-family: Style.mono; vertical-alignment: center; width: 14px; }
                            LineEdit {
                                text <=> root.region-prop-size1;
                                horizontal-stretch: 1;
                                accepted(s) => { root.region-prop-apply(); }
                            }
                            Text { text: "s2"; color: Style.text-dim; font-size: 11px;
                                   font-family: Style.mono; vertical-alignment: center; width: 14px; }
                            LineEdit {
                                text <=> root.region-prop-size2;
                                horizontal-stretch: 1;
                                accepted(s) => { root.region-prop-apply(); }
                            }
                        }
                        // angle row
                        HorizontalLayout {
                            spacing: 4px; height: 24px;
                            Text { text: "θ°"; color: Style.text-dim; font-size: 11px;
                                   font-family: Style.mono; vertical-alignment: center; width: 14px; }
                            LineEdit {
                                text <=> root.region-prop-angle;
                                horizontal-stretch: 1;
                                accepted(s) => { root.region-prop-apply(); }
                            }
                        }
                        // color hex row
                        HorizontalLayout {
                            spacing: 4px; height: 24px;
                            Text { text: "#"; color: Style.text-dim; font-size: 11px;
                                   font-family: Style.mono; vertical-alignment: center; width: 14px; }
                            LineEdit {
                                text <=> root.region-prop-color;
                                horizontal-stretch: 1;
                                placeholder-text: "#rrggbb";
                                accepted(s) => { root.region-prop-apply(); }
                            }
                        }
                        // text body (only meaningful for Text shape)
                        HorizontalLayout {
                            spacing: 4px; height: 24px;
                            Text { text: "t"; color: Style.text-dim; font-size: 11px;
                                   font-family: Style.mono; vertical-alignment: center; width: 14px; }
                            LineEdit {
                                text <=> root.region-prop-text;
                                horizontal-stretch: 1;
                                accepted(s) => { root.region-prop-apply(); }
                            }
                        }

                        // status line
                        Text {
                            text: root.region-prop-status;
                            color: Style.text-dim;
                            font-size: 10px;
                            font-family: Style.mono;
                            wrap: word-wrap;
                        }

                        // buttons
                        HorizontalLayout {
                            spacing: 6px; height: 26px;
                            Button {
                                text: "Apply";
                                clicked => { root.region-prop-apply(); }
                            }
                            Button {
                                text: "Revert";
                                clicked => { root.region-prop-revert(); }
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }
                    }
                }

                // floating HDU navigator panel
                if root.hdu-panel-visible: Rectangle {
                    x: 12px;
                    y: 40px;
                    width: 360px;
                    height: 280px;
                    background: Style.bg-panel;
                    border-color: Style.border-hi;
                    border-width: 1px;
                    border-radius: 3px;

                    Text {
                        x: 8px; y: 4px;
                        text: "HDU NAVIGATOR  " + root.hdu-source-name;
                        color: Style.accent;
                        font-size: 10px;
                        font-family: Style.mono;
                    }
                    Rectangle {
                        x: parent.width - 22px; y: 3px;
                        width: 18px; height: 18px;
                        background: hcta.has-hover ? Style.bg-hover : transparent;
                        border-radius: 2px;
                        Text {
                            x: 4px; y: -1px;
                            text: "×";
                            color: Style.text;
                            font-size: 14px;
                            font-family: Style.mono;
                        }
                        hcta := TouchArea {
                            clicked => { root.hdu-panel-visible = false; }
                        }
                    }
                    Rectangle {
                        x: 8px; y: 22px;
                        width:  parent.width  - 16px;
                        height: parent.height - 30px;
                        background: Style.bg-sunken;
                        border-color: Style.border;
                        border-width: 1px;

                        ScrollView {
                            x: 1px; y: 1px;
                            width:  parent.width  - 2px;
                            height: parent.height - 2px;
                            VerticalLayout {
                                spacing: 0px;
                                for r[i] in root.hdu-rows: Rectangle {
                                    height: 18px;
                                    background: r.active
                                        ? Style.accent-dim
                                        : (hrta.has-hover && r.loadable
                                            ? Style.bg-hover : transparent);
                                    HorizontalLayout {
                                        padding-left: 6px; padding-right: 6px;
                                        Text {
                                            text: r.label;
                                            color: r.loadable ? Style.text : Style.text-dim;
                                            font-size: 10px;
                                            font-family: Style.mono;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                        }
                                    }
                                    hrta := TouchArea {
                                        enabled: r.loadable;
                                        clicked => { root.hdu-row-clicked(r.idx); }
                                    }
                                }
                            }
                        }
                    }
                }

                // floating radial-profile panel (mean flux per r-bin in a
                // selected Circle / Ellipse / Annulus aperture)
                if root.radial-visible: Rectangle {
                    x: parent.width - 412px;
                    y: 40px;
                    width: 400px;
                    height: 230px;
                    background: Style.bg-panel;
                    border-color: Style.border-hi;
                    border-width: 1px;
                    border-radius: 3px;

                    Text {
                        x: 8px; y: 4px;
                        text: root.radial-caption;
                        color: Style.accent;
                        font-size: 10px;
                        font-family: Style.mono;
                    }
                    Rectangle {
                        x: parent.width - 22px; y: 3px;
                        width: 18px; height: 18px;
                        background: rcta.has-hover ? Style.bg-hover : transparent;
                        border-radius: 2px;
                        Text {
                            x: 4px; y: -1px;
                            text: "×";
                            color: Style.text;
                            font-size: 14px;
                            font-family: Style.mono;
                        }
                        rcta := TouchArea {
                            clicked => { root.radial-visible = false; }
                        }
                    }
                    Image {
                        x: 8px; y: 24px;
                        width:  parent.width  - 16px;
                        height: parent.height - 32px;
                        source: root.radial-image;
                        image-fit: fill;
                        image-rendering: smooth;
                    }
                }

                // floating projection panel (1D pixel profile along a Line region)
                if root.projection-visible: Rectangle {
                    x: parent.width - 412px;
                    y: parent.height - 250px;
                    width: 400px;
                    height: 230px;
                    background: Style.bg-panel;
                    border-color: Style.border-hi;
                    border-width: 1px;
                    border-radius: 3px;

                    Text {
                        x: 8px; y: 4px;
                        text: root.projection-caption;
                        color: Style.accent;
                        font-size: 10px;
                        font-family: Style.mono;
                    }
                    Rectangle {
                        x: parent.width - 22px; y: 3px;
                        width: 18px; height: 18px;
                        background: pcta.has-hover ? Style.bg-hover : transparent;
                        border-radius: 2px;
                        Text {
                            x: 4px; y: -1px;
                            text: "×";
                            color: Style.text;
                            font-size: 14px;
                            font-family: Style.mono;
                        }
                        pcta := TouchArea {
                            clicked => { root.projection-visible = false; }
                        }
                    }
                    Image {
                        x: 8px; y: 24px;
                        width:  parent.width  - 16px;
                        height: parent.height - 32px;
                        source: root.projection-image;
                        image-fit: fill;
                        image-rendering: smooth;
                    }
                }
            }

            // sidebar: panner + magnifier
            VerticalLayout {
                width: Style.sidebar-w;
                padding: 4px;
                spacing: 4px;
                if root.panner-visible: Panner {
                    caption: "PANNER";
                    height: 150px;
                    source: root.fits-image;
                    img-w: root.fits-width;
                    img-h: root.fits-height;
                    view-x: root.vp-x;
                    view-y: root.vp-y;
                    view-w: root.vp-w;
                    view-h: root.vp-h;
                    panned(ix, iy) => { root.recenter-view-on(ix, iy); }
                }
                if root.magnifier-visible: Magnifier {
                    caption: "MAGNIFIER";
                    height: 150px;
                    source: root.fits-image;
                    img-w: root.fits-width;
                    img-h: root.fits-height;
                    cursor-x: root.cursor-image-x;
                    cursor-y: root.cursor-image-y;
                    mag: 8.0;
                }
                CatalogPanel {
                    caption: "CATALOG";
                    rows: root.catalog-rows;
                    selected: root.catalog-selected;
                    vertical-stretch: 1;
                    row-clicked(i) => { root.catalog-row-activated(i); }
                }
            }
        }

        Rectangle { height: 1px; background: Style.border; }

        // ---------------- mode buttons ----------------
        Rectangle {
            background: Style.bg-panel;
            height: Style.row-h-mode;
            HorizontalLayout {
                padding-left: 8px; padding-right: 8px; padding-top: 4px; padding-bottom: 4px;
                spacing: 4px;
                ModeButton { label: "edit";      active: root.active-mode == "edit";      clicked => { root.set-mode("edit"); } }
                ModeButton { label: "crosshair"; active: root.active-mode == "crosshair"; clicked => { root.set-mode("crosshair"); } }
                ModeButton { label: "colorbar";  active: root.active-mode == "colorbar";  clicked => { root.set-mode("colorbar"); } }
                ModeButton { label: "pan";       active: root.active-mode == "pan";       clicked => { root.set-mode("pan"); } }
                ModeButton { label: "zoom";      active: root.active-mode == "zoom";      clicked => { root.set-mode("zoom"); } }
                ModeButton { label: "rotate";    active: root.active-mode == "rotate";    clicked => { root.set-mode("rotate"); } }
                ModeButton { label: "crop";      active: root.active-mode == "crop";      clicked => { root.set-mode("crop"); } }
                ModeButton { label: "catalog";   active: root.active-mode == "catalog";   clicked => { root.set-mode("catalog"); } }
                ModeButton { label: "examine";   active: root.active-mode == "examine";   clicked => { root.set-mode("examine"); } }
                ModeButton { label: "iexam";     active: root.active-mode == "iexam";     clicked => { root.set-mode("iexam"); } }
                ModeButton { label: "3d";        active: root.active-mode == "3d";        clicked => { root.set-mode("3d"); } }
                Rectangle { horizontal-stretch: 1; }
                ModeButton { label: "Open File…"; clicked => { root.request-open-file(); } }
            }
        }

        // ---------------- status bar ----------------
        Rectangle {
            background: Style.bg-sunken;
            height: Style.row-h-status;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 8px;
                Text {
                    text: "▸";
                    color: Style.accent;
                    vertical-alignment: center;
                    font-family: Style.mono;
                    font-size: 11px;
                }
                Text {
                    text: root.status-text;
                    color: Style.text-dim;
                    vertical-alignment: center;
                    font-family: Style.mono;
                    font-size: 11px;
                    horizontal-stretch: 1;
                }
                Text {
                    text: "ds9-rust 0.1";
                    color: Style.text-dim;
                    vertical-alignment: center;
                    font-family: Style.mono;
                    font-size: 11px;
                }
            }
        }
    }
}
